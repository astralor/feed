---
import { getCollection } from "astro:content";
import type { GetStaticPathsOptions } from "astro";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Card from "@/components/Card.astro";
import Pagination from "@/components/Pagination.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import { SITE } from "@/config";
import { CATEGORIES } from "@/constants";

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
  const posts = await getCollection("blog");
  const sortedPosts = getSortedPosts(posts);

  return CATEGORIES.flatMap(cat => {
    const catPosts = sortedPosts.filter(
      ({ data }) => data.category === cat.key
    );
    return paginate(catPosts, {
      params: { category: cat.slug },
      props: { categoryName: cat.label, categoryColor: cat.color },
      pageSize: SITE.postPerPage,
    });
  });
}

const { page, categoryName, categoryColor } = Astro.props;
---

<Layout title={`${categoryName} | ${SITE.title}`}>
  <Header />
  <main id="main-content" class="app-layout pt-8 pb-4">
    <h1 class="text-2xl font-semibold sm:text-3xl">
      <span class="inline-block w-3 h-3 rounded-full mr-2 align-middle" style={`background:${categoryColor}`}></span>
      {categoryName}
    </h1>
    <p class="mt-2 mb-6 text-sm text-text-secondary">{page.total} 篇文章</p>
    <ul>
      {page.data.map(data => <Card {...data} />)}
    </ul>
  </main>

  <Pagination {page} />

  <Footer noMarginTop={page.lastPage > 1} />
</Layout>
