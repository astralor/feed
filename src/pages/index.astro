---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import LinkButton from "@/components/LinkButton.astro";
import Card from "@/components/Card.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import IconRss from "@/assets/icons/IconRss.svg";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import { CATEGORIES } from "@/constants";

const posts = await getCollection("blog");
const sortedPosts = getSortedPosts(posts);

const categoryPosts = CATEGORIES.map(cat => ({
  ...cat,
  posts: sortedPosts
    .filter(({ data }) => data.category === cat.key)
    .slice(0, 5),
}));

const uncategorized = sortedPosts.filter(
  ({ data }) => !data.category || !CATEGORIES.some(c => c.key === data.category)
);
---

<Layout>
  <Header />
  <main id="main-content" data-layout="index" class="app-layout">
    <section id="hero" class="pt-8 pb-6">
      <div class="flex items-center gap-3">
        <h1 class="inline-block text-3xl font-bold sm:text-4xl">
          AI Feed
        </h1>
        <a
          target="_blank"
          href="/rss.xml"
          class="inline-block"
          aria-label="rss feed"
          title="RSS Feed"
        >
          <IconRss
            width={20}
            height={20}
            class="scale-125 stroke-accent stroke-3 rtl:-rotate-90"
          />
        </a>
      </div>
      <p class="mt-2 text-sm opacity-60">
        每日精选 AI 领域动态 · 论文 · 开源项目 · 行业趋势
      </p>
    </section>

    <div class="grid grid-cols-1 gap-6 md:grid-cols-2 pb-8">
      {categoryPosts.map(cat =>
        cat.posts.length > 0 && (
          <section class="rounded-xl border border-border bg-muted/20 p-5">
            <div class="flex items-center justify-between mb-2">
              <h2 class="text-base font-semibold tracking-wide flex items-center gap-2">
                <span
                  class="inline-block w-1 h-4 rounded-sm"
                  style={`background-color: ${cat.color}`}
                />
                {cat.label}
              </h2>
              <a
                href={`/categories/${cat.slug}/`}
                class="text-xs text-accent/70 hover:text-accent hover:underline underline-offset-4 decoration-dashed transition-colors"
              >
                更多 →
              </a>
            </div>
            <ul class="divide-y divide-border/50">
              {cat.posts.map(data => (
                <Card variant="h3" {...data} />
              ))}
            </ul>
          </section>
        )
      )}
    </div>

    {uncategorized.length > 0 && (
      <section class="rounded-xl border border-border bg-muted/20 p-5 mb-6">
        <h2 class="text-base font-semibold tracking-wide mb-2">其他</h2>
        <ul class="divide-y divide-border/50">
          {uncategorized.slice(0, 5).map(data => (
            <Card variant="h3" {...data} showCategory />
          ))}
        </ul>
      </section>
    )}

    <div class="my-8 text-center">
      <LinkButton href="/posts/">
        全部动态
        <IconArrowRight class="inline-block rtl:rotate-180" />
      </LinkButton>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", "/");
    }
  });
</script>
