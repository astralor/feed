---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import LinkButton from "@/components/LinkButton.astro";
import Card from "@/components/Card.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import IconRss from "@/assets/icons/IconRss.svg";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import { CATEGORIES } from "@/constants";

const posts = await getCollection("blog");
const sortedPosts = getSortedPosts(posts);

// Featured: top 3 highest-score recent posts
const featured = sortedPosts
  .filter(p => p.data.score != null)
  .sort((a, b) => (b.data.score ?? 0) - (a.data.score ?? 0))
  .slice(0, 3);

const featuredIds = new Set(featured.map(p => p.id));

const categoryPosts = CATEGORIES.map(cat => ({
  ...cat,
  posts: sortedPosts
    .filter(({ data, id }) => data.category === cat.key && !featuredIds.has(id))
    .slice(0, 5),
}));
---

<Layout>
  <Header />
  <main id="main-content" data-layout="index" class="app-layout">
    <!-- Hero -->
    <section class="pt-6 pb-4">
      <div class="flex items-center gap-3">
        <h1 class="text-2xl font-bold sm:text-3xl">AI Feed</h1>
        <a
          target="_blank"
          href="/rss.xml"
          class="inline-block opacity-40 hover:opacity-100 transition-opacity"
          aria-label="rss feed"
          title="RSS Feed"
        >
          <IconRss width={18} height={18} class="stroke-accent stroke-3" />
        </a>
      </div>
      <p class="mt-1.5 text-sm text-text-secondary">
        每日精选 AI 领域动态 · 论文 · 开源项目 · 行业趋势
      </p>
    </section>

    <!-- Featured / Headlines -->
    {featured.length > 0 && (
      <section class="pb-6">
        <div class="flex items-center gap-2 mb-4">
          <span class="inline-block w-1 h-5 rounded-sm bg-accent" />
          <h2 class="text-base font-bold">重点推荐</h2>
        </div>
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-3">
          {featured.map(post => (
            <ul>
              <Card variant="h3" featured {...post} />
            </ul>
          ))}
        </div>
      </section>
    )}

    <!-- Divider -->
    <hr class="border-border mb-6" />

    <!-- Category sections: 2-column grid -->
    <div class="grid grid-cols-1 gap-8 md:grid-cols-2 pb-8">
      {categoryPosts.map(cat =>
        cat.posts.length > 0 && (
          <section>
            <div class="flex items-center justify-between mb-3 pb-2 border-b-2 border-border">
              <h2 class="text-base font-bold flex items-center gap-2">
                <span
                  class="inline-block w-1 h-4 rounded-sm"
                  style={`background-color: ${cat.color}`}
                />
                {cat.label}
              </h2>
              <a
                href={`/categories/${cat.slug}/`}
                class="text-xs text-text-secondary hover:text-accent transition-colors"
              >
                更多 →
              </a>
            </div>
            <ul class="divide-y divide-border/40">
              {cat.posts.map(data => (
                <Card variant="h3" {...data} />
              ))}
            </ul>
          </section>
        )
      )}
    </div>

    <div class="my-8 text-center">
      <LinkButton
        href="/posts/"
        class="inline-flex items-center gap-1.5 rounded-lg border border-border px-5 py-2.5 text-sm font-medium text-foreground hover:bg-muted hover:border-accent/30 transition-all"
      >
        查看全部动态
        <IconArrowRight class="inline-block rtl:rotate-180" />
      </LinkButton>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", "/");
    }
  });
</script>
