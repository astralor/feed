---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import LinkButton from "@/components/LinkButton.astro";
import Card from "@/components/Card.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import { getPath } from "@/utils/getPath";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import { CATEGORIES } from "@/constants";

const posts = await getCollection("blog");
const sortedPosts = getSortedPosts(posts);

// Featured: top 3 highest-score posts from last 24 hours
const oneDayAgo = new Date(Date.now() - 24 * 60 * 60 * 1000);
const featured = sortedPosts
  .filter(p => p.data.score != null && new Date(p.data.pubDatetime) >= oneDayAgo)
  .sort((a, b) => (b.data.score ?? 0) - (a.data.score ?? 0))
  .slice(0, 3);

const featuredIds = new Set(featured.map(p => p.id));

// Main categories for grid (high interest ones)
const mainCategories = CATEGORIES.filter(c =>
  ["模型动态", "工程实践", "学术前沿", "行业动态"].includes(c.key)
);
const categoryPosts = mainCategories.map(cat => ({
  ...cat,
  posts: sortedPosts
    .filter(({ data, id }) => data.category === cat.key && !featuredIds.has(id))
    .slice(0, 6),
}));

// Sidebar: 深度观点
const opinionPosts = sortedPosts
  .filter(({ data, id }) => data.category === "深度观点" && !featuredIds.has(id))
  .slice(0, 8);

// Sidebar: 算力硬件
const infraPosts = sortedPosts
  .filter(({ data, id }) => data.category === "算力硬件" && !featuredIds.has(id))
  .slice(0, 5);

// Sidebar: 政策伦理
const policyPosts = sortedPosts
  .filter(({ data, id }) => data.category === "政策伦理" && !featuredIds.has(id))
  .slice(0, 5);

// Sidebar: 热门文章 (top scored, not in featured or opinions)
const opinionIds = new Set(opinionPosts.map(p => p.id));
const hotPosts = sortedPosts
  .filter(p => p.data.score != null && !featuredIds.has(p.id) && !opinionIds.has(p.id))
  .sort((a, b) => (b.data.score ?? 0) - (a.data.score ?? 0))
  .slice(0, 6);
---

<Layout>
  <Header />
  <main id="main-content" data-layout="index" class="app-layout">
    <!-- Featured / Headlines -->
    {featured.length > 0 && (
      <section class="py-6">
        <div class="flex items-center gap-2 mb-4">
          <span class="inline-block w-1 h-5 rounded-sm bg-accent" />
          <h2 class="text-base font-bold">重点推荐</h2>
        </div>
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-3 items-stretch">
          {featured.map(post => (
            <ul class="h-full">
              <Card variant="h3" featured {...post} />
            </ul>
          ))}
        </div>
      </section>
    )}

    <!-- Main content + Sidebar layout -->
    <div class="flex flex-col lg:flex-row gap-8 pb-8 border-t border-border pt-6">
      <!-- Left: Main category sections -->
      <div class="flex-1 min-w-0">
        <div class="grid grid-cols-1 gap-8 md:grid-cols-2">
          {categoryPosts.map(cat =>
            cat.posts.length > 0 && (
              <section>
                <div class="flex items-center justify-between mb-3 pb-2 border-b-2 border-border">
                  <h2 class="text-sm font-bold flex items-center gap-2">
                    <span
                      class="inline-block w-1 h-4 rounded-sm"
                      style={`background-color: ${cat.color}`}
                    />
                    {cat.label}
                  </h2>
                  <a
                    href={`/categories/${cat.slug}/`}
                    class="text-xs text-text-secondary hover:text-accent transition-colors"
                  >
                    更多 →
                  </a>
                </div>
                <ul class="divide-y divide-border/40">
                  {cat.posts.map(data => (
                    <Card variant="h3" {...data} />
                  ))}
                </ul>
              </section>
            )
          )}
        </div>
      </div>

      <!-- Right: Sidebar (desktop: right column, mobile: below main) -->
      <aside class="w-full lg:w-72 lg:shrink-0 space-y-8">
        <!-- 深度观点 -->
        {opinionPosts.length > 0 && (
          <section>
            <div class="flex items-center justify-between mb-3 pb-2 border-b-2 border-border">
              <h2 class="text-sm font-bold flex items-center gap-2">
                <span class="inline-block w-1 h-4 rounded-sm bg-red-500" />
                深度观点
              </h2>
              <a
                href="/categories/opinions/"
                class="text-xs text-text-secondary hover:text-accent transition-colors"
              >
                更多 →
              </a>
            </div>
            <ul class="space-y-0">
              {opinionPosts.map((post, i) => (
                <li class="py-2 group">
                  <a
                    href={getPath(post.id, post.filePath)}
                    class="flex items-start gap-2.5"
                  >
                    <span class:list={[
                      "shrink-0 w-5 h-5 rounded text-center text-xs font-bold leading-5",
                      i < 3 ? "bg-accent text-white" : "bg-muted text-text-secondary",
                    ]}>
                      {i + 1}
                    </span>
                    <span class="text-xs font-medium leading-snug text-foreground group-hover:text-accent transition-colors line-clamp-2">
                      {post.data.title}
                    </span>
                  </a>
                </li>
              ))}
            </ul>
          </section>
        )}

        <!-- 算力硬件 -->
        {infraPosts.length > 0 && (
          <section>
            <div class="flex items-center justify-between mb-3 pb-2 border-b-2 border-border">
              <h2 class="text-sm font-bold flex items-center gap-2">
                <span class="inline-block w-1 h-4 rounded-sm bg-emerald-500" />
                算力硬件
              </h2>
              <a
                href="/categories/infrastructure/"
                class="text-xs text-text-secondary hover:text-accent transition-colors"
              >
                更多 →
              </a>
            </div>
            <ul class="space-y-0">
              {infraPosts.map((post, i) => (
                <li class="py-2 group">
                  <a
                    href={getPath(post.id, post.filePath)}
                    class="flex items-start gap-2.5"
                  >
                    <span class:list={[
                      "shrink-0 w-5 h-5 rounded text-center text-xs font-bold leading-5",
                      i < 3 ? "bg-emerald-500 text-white" : "bg-muted text-text-secondary",
                    ]}>
                      {i + 1}
                    </span>
                    <span class="text-xs font-medium leading-snug text-foreground group-hover:text-accent transition-colors line-clamp-2">
                      {post.data.title}
                    </span>
                  </a>
                </li>
              ))}
            </ul>
          </section>
        )}

        <!-- 政策伦理 -->
        {policyPosts.length > 0 && (
          <section>
            <div class="flex items-center justify-between mb-3 pb-2 border-b-2 border-border">
              <h2 class="text-sm font-bold flex items-center gap-2">
                <span class="inline-block w-1 h-4 rounded-sm bg-orange-500" />
                政策伦理
              </h2>
              <a
                href="/categories/policy/"
                class="text-xs text-text-secondary hover:text-accent transition-colors"
              >
                更多 →
              </a>
            </div>
            <ul class="space-y-0">
              {policyPosts.map((post, i) => (
                <li class="py-2 group">
                  <a
                    href={getPath(post.id, post.filePath)}
                    class="flex items-start gap-2.5"
                  >
                    <span class:list={[
                      "shrink-0 w-5 h-5 rounded text-center text-xs font-bold leading-5",
                      i < 3 ? "bg-orange-500 text-white" : "bg-muted text-text-secondary",
                    ]}>
                      {i + 1}
                    </span>
                    <span class="text-xs font-medium leading-snug text-foreground group-hover:text-accent transition-colors line-clamp-2">
                      {post.data.title}
                    </span>
                  </a>
                </li>
              ))}
            </ul>
          </section>
        )}

        <!-- 热门文章 -->
        {hotPosts.length > 0 && (
          <section>
            <div class="flex items-center mb-3 pb-2 border-b-2 border-border">
              <h2 class="text-sm font-bold flex items-center gap-2">
                <span class="inline-block w-1 h-4 rounded-sm bg-amber-500" />
                热门文章
              </h2>
            </div>
            <ul class="space-y-0">
              {hotPosts.map((post, i) => (
                <li class="py-2 group">
                  <a
                    href={getPath(post.id, post.filePath)}
                    class="flex items-start gap-2.5"
                  >
                    <span class:list={[
                      "shrink-0 w-5 h-5 rounded text-center text-xs font-bold leading-5",
                      i < 3 ? "bg-amber-500 text-white" : "bg-muted text-text-secondary",
                    ]}>
                      {i + 1}
                    </span>
                    <div class="min-w-0">
                      <span class="text-xs font-medium leading-snug text-foreground group-hover:text-accent transition-colors line-clamp-2 block">
                        {post.data.title}
                      </span>
                      {post.data.score != null && (
                        <span class="text-[10px] text-amber-500 font-mono font-bold">
                          {post.data.score.toFixed(1)}分
                        </span>
                      )}
                    </div>
                  </a>
                </li>
              ))}
            </ul>
          </section>
        )}
      </aside>
    </div>

    <div class="my-6 text-center">
      <LinkButton
        href="/posts/"
        class="inline-flex items-center gap-1.5 rounded-lg border border-border px-5 py-2.5 text-sm font-medium text-foreground hover:bg-muted hover:border-accent/30 transition-all"
      >
        浏览文章库
        <IconArrowRight class="inline-block rtl:rotate-180" />
      </LinkButton>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", "/");
    }
  });
</script>
