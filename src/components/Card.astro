---
import type { CollectionEntry } from "astro:content";
import { slugifyStr } from "@/utils/slugify";
import { getPath } from "@/utils/getPath";
import Datetime from "./Datetime.astro";
import dayjs from "dayjs";
import utc from "dayjs/plugin/utc";
import tz from "dayjs/plugin/timezone";
import { CATEGORY_LABELS } from "@/constants";
import { SITE } from "@/config";

dayjs.extend(utc);
dayjs.extend(tz);

type Props = {
  variant?: "h2" | "h3";
  showCategory?: boolean;
} & CollectionEntry<"blog">;

const { variant: Heading = "h2", id, data, filePath, showCategory = false } = Astro.props;

const { title, description, score, sourceUrl, sourceName, category, collectedAt, ...props } = data;

const categoryInfo = category ? CATEGORY_LABELS[category] : null;
const scoreDisplay = score != null ? score.toFixed(1) : null;
const scoreColor = score != null
  ? score >= 8 ? "text-red-500" : score >= 6 ? "text-amber-500" : "text-gray-400"
  : "";
const collectedStr = collectedAt
  ? dayjs(collectedAt).tz(SITE.timezone).format("MM/DD HH:mm") + " 采集"
  : null;
---

<li class="py-3 first:pt-1 transition-colors hover:bg-muted/30 -mx-2 px-2 rounded-lg">
  <div class="flex items-start gap-2.5">
    {scoreDisplay && (
      <span class:list={["shrink-0 font-mono text-xs font-bold mt-0.5 tabular-nums", scoreColor]}>
        {scoreDisplay}
      </span>
    )}
    <div class="min-w-0 flex-1">
      <a
        href={getPath(id, filePath)}
        class:list={[
          "inline text-sm font-medium text-foreground leading-snug",
          "decoration-accent/40 underline-offset-4 hover:underline hover:text-accent transition-colors",
          "focus-visible:no-underline focus-visible:underline-offset-0",
        ]}
      >
        <Heading
          style={{ viewTransitionName: slugifyStr(title.replaceAll(".", "-")) }}
          class="inline"
        >
          {title}
        </Heading>
      </a>
      {showCategory && categoryInfo && (
        <span
          class="ml-1.5 inline-block rounded px-1.5 py-px text-[10px] font-medium text-white align-middle"
          style={`background-color: ${categoryInfo.color}`}
        >
          {categoryInfo.label}
        </span>
      )}
      <div class="mt-0.5 flex items-center gap-1.5 text-[11px] opacity-50 flex-wrap">
        <Datetime {...props} size="sm" />
        {sourceName && sourceUrl && (
          <span class="flex items-center gap-1">
            ·
            <a
              href={sourceUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="hover:text-accent hover:underline underline-offset-4 decoration-dashed transition-colors"
            >
              {sourceName}
            </a>
          </span>
        )}
        {sourceName && !sourceUrl && (
          <span>· {sourceName}</span>
        )}
        {collectedStr && (
          <span>· {collectedStr}</span>
        )}
      </div>
      <p class="mt-0.5 text-xs opacity-60 line-clamp-2 leading-relaxed">{description}</p>
    </div>
  </div>
</li>
