---
import IconMoon from "@/assets/icons/IconMoon.svg";
import IconSearch from "@/assets/icons/IconSearch.svg";
import IconSunHigh from "@/assets/icons/IconSunHigh.svg";
import LinkButton from "./LinkButton.astro";
import { SITE } from "@/config";
import { CATEGORIES } from "@/constants";

type Props = {
  activeCategory?: string | null;
};

const { activeCategory } = Astro.props;
const { pathname } = Astro.url;

const currentPath =
  pathname.endsWith("/") && pathname !== "/" ? pathname.slice(0, -1) : pathname;

const isActive = (path: string, slug?: string) => {
  // If activeCategory is set (from article page), use it for category matching
  if (activeCategory && slug) {
    return slug === activeCategory;
  }
  const cleanPath = path.endsWith("/") && path !== "/" ? path.slice(0, -1) : path;
  return currentPath === cleanPath || currentPath.startsWith(cleanPath + "/");
};

// Nav categories: all categories shown in nav
const navCategories = CATEGORIES;
---

<a
  id="skip-to-content"
  href="#main-content"
  class="absolute start-16 -top-full z-50 bg-background px-3 py-2 text-accent backdrop-blur-lg transition-all focus:top-4"
>
  Skip to content
</a>

<header class="border-b border-border bg-background sticky top-0 z-40">
  <div class="app-layout flex items-center h-14 gap-8">
    <!-- Logo -->
    <a
      href="/"
      class="text-lg font-bold tracking-tight text-foreground hover:text-accent transition-colors shrink-0"
    >
      {SITE.title}
    </a>

    <!-- Category tabs (desktop) -->
    <nav class="hidden sm:flex items-center gap-0 overflow-x-auto -mb-px h-full flex-1">
      {navCategories.map(cat => (
        <a
          href={`/categories/${cat.slug}/`}
          class:list={[
            "whitespace-nowrap px-4 h-full flex items-center text-sm font-medium border-b-2 transition-colors",
            isActive(`/categories/${cat.slug}`, cat.slug)
              ? "border-accent text-accent"
              : "border-transparent text-text-secondary hover:text-foreground hover:border-border",
          ]}
        >
          {cat.label}
        </a>
      ))}
      <a
        href="/library"
        class:list={[
          "whitespace-nowrap px-4 h-full flex items-center text-sm font-medium border-b-2 transition-colors",
          !activeCategory && isActive("/library")
            ? "border-accent text-accent"
            : "border-transparent text-text-secondary hover:text-foreground hover:border-border",
        ]}
      >
        文章库
      </a>
    </nav>

    <!-- Right: utilities -->
    <div class="flex items-center gap-1 shrink-0">
      <LinkButton
        href="/search"
        class:list={[
          "focus-outline flex p-2 rounded-lg hover:bg-muted transition-colors",
          { "[&>svg]:stroke-accent": isActive("/search") },
        ]}
        title="Search"
        aria-label="search"
      >
        <IconSearch />
      </LinkButton>
      {SITE.lightAndDarkMode && (
        <button
          id="theme-btn"
          class="focus-outline relative size-9 p-2 rounded-lg hover:bg-muted transition-colors hover:[&>svg]:stroke-accent"
          title="Toggles light & dark"
          aria-label="auto"
          aria-live="polite"
        >
          <IconMoon class="absolute top-[50%] left-[50%] -translate-[50%] scale-100 rotate-0 transition-all dark:scale-0 dark:-rotate-90" />
          <IconSunHigh class="absolute top-[50%] left-[50%] -translate-[50%] scale-0 rotate-90 transition-all dark:scale-100 dark:rotate-0" />
        </button>
      )}
    </div>
  </div>

  <!-- Mobile category tabs (horizontal scroll) -->
  <nav class="sm:hidden flex items-center gap-0 overflow-x-auto border-t border-border/50 -mb-px">
    {navCategories.map(cat => (
      <a
        href={`/categories/${cat.slug}/`}
        class:list={[
          "whitespace-nowrap px-3 py-2 text-xs font-medium border-b-2 transition-colors",
          isActive(`/categories/${cat.slug}`, cat.slug)
            ? "border-accent text-accent"
            : "border-transparent text-text-secondary",
        ]}
      >
        {cat.label}
      </a>
    ))}
    <a
      href="/library"
      class:list={[
        "whitespace-nowrap px-3 py-2 text-xs font-medium border-b-2 transition-colors",
        !activeCategory && isActive("/library")
          ? "border-accent text-accent"
          : "border-transparent text-text-secondary",
      ]}
    >
      文章库
    </a>
  </nav>
</header>
