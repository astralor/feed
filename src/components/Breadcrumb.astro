---
import { CATEGORIES } from "@/constants";

const currentUrlPath = Astro.url.pathname.replace(/\/+$/, "");
const segments = currentUrlPath.split("/").filter(Boolean);

// Build breadcrumb items with Chinese labels
const CAT_SLUG_MAP: Record<string, string> = {};
CATEGORIES.forEach(c => { CAT_SLUG_MAP[c.slug] = c.label; });

type BreadcrumbItem = { label: string; href?: string };
const items: BreadcrumbItem[] = [{ label: "首页", href: "/" }];

if (segments[0] === "categories" && segments[1]) {
  const catLabel = CAT_SLUG_MAP[segments[1]] || segments[1];
  items.push({ label: catLabel });
  // If there's a page number
  if (segments[2] && !isNaN(Number(segments[2]))) {
    items[items.length - 1].href = `/categories/${segments[1]}/`;
    items.push({ label: `第 ${segments[2]} 页` });
  }
} else if (segments[0] === "posts") {
  if (segments.length > 1) {
    items.push({ label: "文章库", href: "/library" });
  } else {
    items.push({ label: "文章库" });
  }
} else if (segments[0] === "tags") {
  items.push({ label: "标签", href: "/tags/" });
  if (segments[1]) {
    items.push({ label: decodeURIComponent(segments[1]) });
  }
} else if (segments[0] === "library") {
  items.push({ label: "文章库" });
} else if (segments.length > 0) {
  segments.forEach((seg, i) => {
    const isLast = i === segments.length - 1;
    items.push({
      label: decodeURIComponent(seg),
      href: isLast ? undefined : `/${segments.slice(0, i + 1).join("/")}/`,
    });
  });
}
---

<nav class="app-layout mt-6 mb-1" aria-label="breadcrumb">
  <div class="flex items-center gap-1.5 text-sm text-text-secondary">
    {items.map((item, i) => (
      <>
        {i > 0 && <span class="opacity-50">/</span>}
        {item.href ? (
          <a href={item.href} class="hover:text-accent transition-colors">
            {item.label}
          </a>
        ) : (
          <span class="text-foreground font-medium" aria-current="page">
            {item.label}
          </span>
        )}
      </>
    ))}
  </div>
</nav>
